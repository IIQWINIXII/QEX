<div class="page-layout-component">
    <div class="page-tabs">
        @foreach (var tab in Pages)
        {
            <div class=@("tab-button " + (tab == ActivePage ? "active" : ""))
                    @onclick="() => Activate(tab)">
                @tab.Title
                <button class="close-page-button">
                    X
                </button>
            </div>
        }
        @if (CanAddPage)
        {
            <button class="tab-button-add-page" @onclick="AddPage">+</button>
        }

        
    </div>

    <div class="page-content">
        @ActivePage?.ChildContent
    </div>

    <div style="display:none">
        <CascadingValue Value="this">
            @ChildContent
        </CascadingValue>
    </div>
</div>

<style>
    .page-layout-component .page-tabs {
        display: flex;
        border-bottom: 1px solid #ccc;
        height: 100%;
    }

    .page-layout-component .tab-button {
        background: #f3f3f3;
        border: 0px none #ccc;
        border-radius: 6px 6px 0 0;
        border-color: transparent;
        cursor: pointer;
        font-size: 14px;
        color: #333;
        transition: 0.2s;
        height: 20px;
    }

        .page-layout-component .tab-button:hover {
            background: #e8e8e8;
        }

        .page-layout-component .tab-button.active {
            background: white;
            border: 1px solid #ccc;
            font-weight: 600;
            color: #000;
        }

    .page-layout-component .page-content {
        border-radius: 0 6px 6px 6px;
        background: white;
        height: 100%;
    }

    .page-layout-component .close-page-button {
        border-radius: 0 6px 6px 6px;
        background: none;
        border-color: transparent;
        height: 100%;
    }
    .page-layout-component .tab-button-add-page{
        border-color: transparent;
    }
</style>

@code {
    [Parameter] public int Width { get; set; } = 200;
    [Parameter] public int Height { get; set; } = 200;

    [Parameter] public int MaxWidth { get; set; } = int.MaxValue;
    [Parameter] public int MaxHeigth { get; set; } = int.MaxValue;

    [Parameter] public int MinWidth { get; set; } = 0;
    [Parameter] public int MinHeight { get; set; } = 0;

    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public RenderFragment? OnCreateNewPageFragment { get; set; }
    [Parameter] public bool CanAddPage { get; set; }

    [Parameter] public EventCallback OnClick { get; set; }

    internal List<TabPage> Pages { get; } = new();

    internal TabPage? ActivePage { get; set; }

    public void AddPage()
    {
        if (OnCreateNewPageFragment is not null)
            AddPage("Новая вкладка", OnCreateNewPageFragment);
        else
            AddPage("Новая вкладка", builder => { });
}

    public void AddPage(string? title, RenderFragment? content)
    {
        if (string.IsNullOrEmpty(title))
            title = "Новая вкладка";
        var page = new TabPage { Title = title, ChildContent = content };
        Register(page);
        Activate(page);
    }

    internal void Register(TabPage page)
    {
        Pages.Add(page);

        if (ActivePage is null)
            ActivePage = page;

        StateHasChanged();
    }

    internal void Unregister(TabPage page)
    {
        if (Pages.Remove(page))
        {
            if (ActivePage == page)
                ActivePage = Pages.Count > 0 ? Pages[0] : null;

            StateHasChanged();
        }
    }

    private void Activate(TabPage page)
    {
        ActivePage = page;
        StateHasChanged();
    }

    
}
