@using QEX_Lib.ClientDB.Model;

<div class="profile-root">
    <div class="profile-header">
        <div class="profile-banner"></div>

        <div class="profile-avatar-wrapper">
            <div class="profile-avatar">
                @if (!string.IsNullOrEmpty(User.CurrentAvatarID))
                {
                    <img src="@UserAvatarList.GetImageFromBase64ByID(User.CurrentAvatarID)"
                         class="avatar-img" />
                }
                else
                {
                    <div class="avatar-placeholder">@User.Name[0]</div>
                }
            </div>
        </div>

        <div class="profile-name">
            <span>@User.Name</span>
        </div>
    </div>

    <div class="profile-body">
        <div class="profile-section">
            <h3>Основная информация</h3>
            <div class="info-row"><b>Логин:</b> @User.Login</div>
            <div class="info-row"><b>Email:</b> @User.Email</div>
        </div>

        <div class="profile-section">
            <h3>Дополнительно</h3>
            <div class="custom-info">
                @* Здесь можно выводить кастомные поля *@
            </div>
        </div>

        <div class="profile-actions">
            <button class="edit-btn">Редактировать</button>
        </div>
    </div>
</div>

<style>
    .profile-root {
        width: 100%;
        height: 100%;
        background: #2f3136;
        color: white;
        font-family: sans-serif;
        display: flex;
        flex-direction: column;
    }

    .profile-header {
        position: relative;
        height: 180px;
        background: #202225;
    }

    .profile-banner {
        width: 100%;
        height: 120px;
        background: linear-gradient(135deg, #5865F2, #3a3c43);
    }

    .profile-avatar-wrapper {
        position: absolute;
        bottom: -40px;
        left: 20px;
    }

    .profile-avatar {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        overflow: hidden;
        border: 4px solid #2f3136;
        background: #3a3c43;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .avatar-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .avatar-placeholder {
        font-size: 32px;
        font-weight: bold;
        color: #ccc;
    }

    .profile-name {
        margin-left: 120px;
        margin-top: 10px;
        font-size: 22px;
        font-weight: bold;
    }

    .profile-body {
        padding: 20px;
        margin-top: 40px;
    }

    .profile-section {
        margin-bottom: 20px;
    }

        .profile-section h3 {
            margin-bottom: 10px;
            font-size: 16px;
            color: #b9bbbe;
        }

    .info-row {
        margin-bottom: 6px;
    }

    .profile-actions {
        display: flex;
        gap: 10px;
        margin-top: 20px;
    }

    .edit-btn, .close-btn {
        padding: 8px 14px;
        border: none;
        border-radius: 4px;
        cursor: pointer;
    }

    .edit-btn {
        background: #5865F2;
        color: white;
    }

    .close-btn {
        background: #3a3c43;
        color: white;
    }
</style>

@code {
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public User User { get; set; } = new();
    public UserAvatarList UserAvatarList { get; set; } = new();
}
