@using QEX.Resources.Data
@using QEX.Components.Extensions.Base.OptionPage
@inject IJSRuntime JSRuntime

<div class="options-overlay" @onclick="HandleOverlayClick">
    <div class="options-modal" @onclick:stopPropagation="true">
        <div class="options-container">
            <div class="options-header">
                <h2>⚙️ Настройки приложения</h2>
                <div class="header-actions">
                    <span class="status-indicator @(hasChanges ? "has-changes" : "")">
                        @if (hasChanges)
                        {
                            <span class="unsaved-badge">●</span>
                        }
                    </span>
                    <button class="close-btn" @onclick='() => HandleClose("close-btn")' title="Закрыть">
                        ✕
                    </button>
                </div>
            </div>
            <div class="main-actions">
                <div class="options-tabs">
                    <button class="tab-btn @(activeTab == TabType.Interface ? "active" : "")"
                            @onclick="() => SetActiveTab(TabType.Interface)">
                        <span class="tab-icon">🎨</span>
                        <span class="tab-label">Интерфейс</span>
                    </button>
                    <button class="tab-btn @(activeTab == TabType.Security ? "active" : "")"
                            @onclick="() => SetActiveTab(TabType.Security)">
                        <span class="tab-icon">🔒</span>
                        <span class="tab-label">Безопасность</span>
                    </button>
                    <button class="tab-btn @(activeTab == TabType.Extensions ? "active" : "")"
                            @onclick="() => SetActiveTab(TabType.Extensions)">
                        <span class="tab-icon">🔌</span>
                        <span class="tab-label">Расширения</span>
                    </button>
                </div>

                <div class="options-content">
                    @switch (activeTab)
                    {
                        case TabType.Interface:
                            <InterfaceSettingsTab Settings="options.interfaceSetting"
                                                  OnSettingsChanged="MarkAsChanged" />
                            break;
                        case TabType.Security:
                            <SecuritySettingsTab Settings="options.securitySetting"
                                                 OnSettingsChanged="MarkAsChanged" />
                            break;
                        case TabType.Extensions:
                            <ExtensionSettingsTab Settings="options.extensionSetting"
                                                  OnSettingsChanged="MarkAsChanged" />
                            break;
                    }
                </div>
            </div>
            <div class="options-footer">
                <div class="footer-info">
                    @if (lastSaveTime.HasValue)
                    {
                        <span class="save-info">Последнее сохранение: @lastSaveTime.Value.ToString("HH:mm:ss")</span>
                    }
                    @if (notificationMessage != null)
                    {
                        <span class="notification @notificationType">@notificationMessage</span>
                    }
                </div>
                <div class="footer-actions">
                    <button class="btn-secondary" @onclick="CancelChanges"
                            disabled="@(!hasChanges)">
                        <span class="btn-icon">↩</span> Отмена
                    </button>
                    <button class="btn-primary" @onclick="SaveSettings"
                            disabled="@(!hasChanges)">
                        <span class="btn-icon">💾</span> Сохранить
                    </button>
                </div>
            </div>
        </div>

        @if (isSaving)
        {
            <div class="saving-overlay">
                <div class="spinner"></div>
                <span>Сохранение...</span>
            </div>
        }
    </div>
</div>
<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        color: white;
    }

    /* Overlay - затемнение фона */
    .options-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.7);
        backdrop-filter: blur(4px);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 10000;
        animation: fadeIn 0.2s ease;
    }

    /* Модальное окно */
    .options-modal {
        width: 900px;
        max-width: 90vw;
        height: 600px;
        max-height: 85vh;
        background: #2f3136;
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(255, 255, 255, 0.05);
        overflow: hidden;
        animation: slideIn 0.25s cubic-bezier(0.2, 0.9, 0.4, 1.1);
    }

    

    /* Контейнер с флекс-структурой */
    .options-container {
        display: flex;
        flex-direction: column;
        height: 100%;
        background: #2f3136;
    }

    /* Хедер */
    .options-header {
        padding: 16px 20px;
        background: #202225;
        border-bottom: 1px solid #18191c;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

        .options-header h2 {
            font-size: 18px;
            font-weight: 600;
            color: #ffffff;
            letter-spacing: -0.2px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

    .header-actions {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    /* Индикатор статуса */
    .status-indicator {
        display: flex;
        align-items: center;
    }

    .unsaved-badge {
        color: #faa81a;
        font-size: 18px;
        animation: pulse 1.5s infinite;
    }

    

    /* Кнопка закрытия */
    .close-btn {
        background: none;
        border: none;
        color: #b9bbbe;
        font-size: 20px;
        cursor: pointer;
        padding: 4px 8px;
        border-radius: 6px;
        transition: all 0.2s ease;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .close-btn:hover {
            background: #3a3c43;
            color: #ffffff;
        }

    /* Основная область (табы + контент) */
    .main-actions {
        display: flex;
        flex: 1;
        overflow: hidden;
    }

    /* Боковая панель с табами */
    .options-tabs {
        width: 200px;
        background: #202225;
        border-right: 1px solid #18191c;
        padding: 12px 8px;
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .tab-btn {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px 12px;
        background: none;
        border: none;
        border-radius: 8px;
        color: #b9bbbe;
        font-size: 14px;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s ease;
        text-align: left;
        width: 100%;
    }

        .tab-btn:hover {
            background: #2f3136;
            color: #dcddde;
        }

        .tab-btn.active {
            background: #3a3c43;
            color: #ffffff;
        }

    .tab-icon {
        font-size: 18px;
    }

    .tab-label {
        flex: 1;
    }

    /* Область контента */
    .options-content {
        flex: 1;
        padding: 20px 24px;
        overflow-y: auto;
        background: #2f3136;
    }

        /* Стилизация скроллбара */
        .options-content::-webkit-scrollbar {
            width: 8px;
        }

        .options-content::-webkit-scrollbar-track {
            background: #202225;
            border-radius: 4px;
        }

        .options-content::-webkit-scrollbar-thumb {
            background: #4a4c53;
            border-radius: 4px;
        }

            .options-content::-webkit-scrollbar-thumb:hover {
                background: #5a5c63;
            }

    /* Футер */
    .options-footer {
        padding: 14px 20px;
        background: #202225;
        border-top: 1px solid #18191c;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .footer-info {
        display: flex;
        align-items: center;
        gap: 12px;
        font-size: 12px;
    }

    .save-info {
        color: #72767d;
    }

    .notification {
        padding: 4px 10px;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 500;
        animation: slideInRight 0.3s ease;
    }

    

    .notification.success {
        background: #1a472a;
        color: #6fcf97;
    }

    .notification.error {
        background: #4a2a2a;
        color: #e06c6c;
    }

    .notification.info {
        background: #2a3a4a;
        color: #6ca0cf;
    }

    .footer-actions {
        display: flex;
        gap: 12px;
    }

    /* Кнопки */
    .btn-primary, .btn-secondary {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 18px;
        border-radius: 6px;
        font-size: 13px;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s ease;
        border: none;
    }

    .btn-primary {
        background: #5865f2;
        color: white;
    }

        .btn-primary:hover:not(:disabled) {
            background: #4752c4;
            transform: translateY(-1px);
        }

        .btn-primary:active:not(:disabled) {
            transform: translateY(0);
        }

    .btn-secondary {
        background: #3a3c43;
        color: #dcddde;
    }

        .btn-secondary:hover:not(:disabled) {
            background: #4a4c53;
        }

        .btn-primary:disabled, .btn-secondary:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

    .btn-icon {
        font-size: 14px;
    }

    /* Saving overlay */
    .saving-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(32, 34, 37, 0.9);
        backdrop-filter: blur(2px);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 12px;
        z-index: 10;
    }

    .spinner {
        width: 32px;
        height: 32px;
        border: 3px solid #3a3c43;
        border-top-color: #5865f2;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
    }

    

    .saving-overlay span {
        color: #ffffff;
        font-size: 14px;
        font-weight: 500;
    }

    /* Стили для групп настроек внутри табов */
    .settings-group {
        margin-bottom: 24px;
    }

        .settings-group h3 {
            font-size: 14px;
            font-weight: 600;
            color: #ffffff;
            margin-bottom: 12px;
            padding-bottom: 6px;
            border-bottom: 1px solid #404249;
        }

    .setting-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 10px 0;
        border-bottom: 1px solid #3a3c43;
    }

        .setting-row:last-child {
            border-bottom: none;
        }

    .setting-label {
        font-size: 13px;
        color: #dcddde;
    }

    .setting-description {
        font-size: 11px;
        color: #72767d;
        margin-top: 4px;
    }

    /* Toggle switch */
    .toggle-switch {
        position: relative;
        display: inline-block;
        width: 44px;
        height: 22px;
    }

        .toggle-switch input {
            opacity: 0;
            width: 0;
            height: 0;
        }

    .toggle-slider {
        position: absolute;
        cursor: pointer;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-color: #3a3c43;
        transition: 0.2s;
        border-radius: 22px;
    }

        .toggle-slider:before {
            position: absolute;
            content: "";
            height: 18px;
            width: 18px;
            left: 2px;
            bottom: 2px;
            background-color: #b9bbbe;
            transition: 0.2s;
            border-radius: 50%;
        }

    input:checked + .toggle-slider {
        background-color: #5865f2;
    }

        input:checked + .toggle-slider:before {
            transform: translateX(22px);
            background-color: white;
        }

    /* Select и input стили */
    .setting-select, .setting-input {
        background: #3a3c43;
        border: 1px solid #202225;
        border-radius: 6px;
        padding: 6px 12px;
        color: #ffffff;
        font-size: 13px;
        outline: none;
        transition: all 0.2s;
    }

        .setting-select:focus, .setting-input:focus {
            border-color: #5865f2;
            background: #4a4c53;
        }

    /* Чекбокс */
    .checkbox-label {
        display: flex;
        align-items: center;
        gap: 8px;
        cursor: pointer;
    }

        .checkbox-label input {
            width: 16px;
            height: 16px;
            cursor: pointer;
            accent-color: #5865f2;
        }

</style>
@code {
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnSettingsSaved { get; set; }

    private enum TabType { Interface, Security, Extensions }
    private TabType activeTab = TabType.Interface;
    private Options options = new();
    private bool hasChanges = false;
    private bool isSaving = false;
    private DateTime? lastSaveTime;
    private string? notificationMessage;
    private string notificationType = "success";

    protected override void OnInitialized()
    {
        try
        {
            options.LoadSetting();
            Console.WriteLine("Settings loaded successfully");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading settings: {ex.Message}");
            ShowNotification("Ошибка загрузки настроек", "error");
        }
    }

    private void MarkAsChanged()
    {
        hasChanges = true;
        StateHasChanged();
    }

    private void SetActiveTab(TabType tab)
    {
        activeTab = tab;
        StateHasChanged();
    }

    private async Task SaveSettings()
    {
        if (isSaving) return;

        try
        {
            isSaving = true;
            StateHasChanged();

            options.SaveSetting();
            hasChanges = false;
            lastSaveTime = DateTime.Now;
            
            ShowNotification("✅ Настройки успешно сохранены", "success");
            await OnSettingsSaved.InvokeAsync();
            
            // Автоматически скрываем уведомление через 3 секунды
            _ = Task.Run(async () =>
            {
                await Task.Delay(3000);
                await InvokeAsync(() =>
                {
                    notificationMessage = null;
                    StateHasChanged();
                });
            });
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error saving settings: {ex.Message}");
            ShowNotification("❌ Ошибка сохранения настроек", "error");
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }

    private async Task CancelChanges()
    {
        if (hasChanges)
        {
            bool? result = null;
            try
            {
                result = await JSRuntime.InvokeAsync<bool>("confirm",
                    "У вас есть несохранённые изменения. Отменить их?");
            }
            catch
            {
                // Fallback - используем хак с confirm через DOM
                result = await FallbackConfirm();
            }

            if (result == true)
            {
                options.LoadSetting();
                hasChanges = false;
                ShowNotification("Изменения отменены", "info");
                StateHasChanged();
            }
        }
        else
        {
            await SafeClose();
        }
    }

    private async Task HandleClose(string source)
    {
        if (source == "overlay") return; // Игнорируем клик по overlay
        
        if (hasChanges)
        {
            bool? result = null;
            try
            {
                result = await JSRuntime.InvokeAsync<bool>("confirm",
                    "У вас есть несохранённые изменения. Сохранить перед закрытием?");
            }
            catch
            {
                result = await FallbackConfirm();
            }

            if (result == true)
            {
                await SaveSettings();
                await SafeClose();
            }
            else if (result == false)
            {
                options.LoadSetting();
                await SafeClose();
            }
            // Если result == null - пользователь отменил
        }
        else
        {
            await SafeClose();
        }
    }

    private async Task HandleOverlayClick()
    {
        await HandleClose("overlay");
    }

    private async Task SafeClose()
    {
        try
        {
            await OnClose.InvokeAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error during close: {ex.Message}");
        }
    }

    private async Task<bool?> FallbackConfirm()
    {
        // Создаём fallback confirm через JavaScript
        try
        {
            return await JSRuntime.InvokeAsync<bool>("confirm",
                "У вас есть несохранённые изменения. Продолжить?");
        }
        catch
        {
            return true; // По умолчанию продолжаем если JS недоступен
        }
    }

    private void ShowNotification(string message, string type)
    {
        notificationMessage = message;
        notificationType = type;
        StateHasChanged();
    }
}