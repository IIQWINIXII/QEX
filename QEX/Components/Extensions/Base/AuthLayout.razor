@using System.ComponentModel.DataAnnotations;
@using QEX_Lib.ClientDB.Model;
<div class="AuthLayout">
    <div class="AuthDiv">
        <div class="AuthInputDiv">
            <div>
                <input @bind="Login" type="text" class="AuthInput" placeholder="Login"/>
            </div>
            <div>
                <input @bind="Password" type="text" class="AuthInput" placeholder="Password"/>
            </div>
            @if (IsRegisterMode)
            {
                <div>
                    <input type="text" class="AuthInput" placeholder="Confirm Password"/>
                </div>
                <div>
                    <input type="text" class="AuthInput" placeholder="Email (Variant Field)"/>
                </div>
            }
        </div>
        <div class="AuthButtonDiv">
            <button @onclick="RegisterUser" class="AuthActiveButton">Register</button>
            <button @onclick="LoginUser" class="AuthUnActiveButton">Login</button>
        </div>
    </div>
</div>

@code {
    [Parameter] public EventCallback<User> OnUserLoggedIn { get; set; }
    private bool IsRegisterMode { get; set; } = false;
    private bool IsShowWarning { get; set; } = false;
    private string Login { get; set; } = string.Empty;
    [EmailAddress]
    private string Email { get; set; } = string.Empty;
    private string Password { get; set; } = string.Empty;

    public void RegisterUser()
    {
        if (IsRegisterMode)
        {
            if (Login.Length < 1)
            {
                // show error
                return;
            }
            else if (Password.Length < 6)
            {
                // show error
                return;
            }
            else
                if (!IsShowWarning)
            {
                IsShowWarning = true;
                return;
            }
            else return;
            //reg

        }
        else
        {
            IsRegisterMode = true;
        }
    }
    public void LoginUser()
    {
        if (!IsRegisterMode)
        {
            if(Login.Length < 1)
            {
                // show error
                return;
            }
            else if (Password.Length < 6)
            {
                // show error
                return;
            }
            else
            {
                OnUserLoggedIn.InvokeAsync(new User() { Login = Login, Password = Password });
                // getUserData from server and invoke callback
                return;
            }

                //login)
        }
        else
        {
            IsRegisterMode = false;
        }
    }
}
