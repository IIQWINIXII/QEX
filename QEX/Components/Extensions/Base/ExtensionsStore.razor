@using QEX.Abstractions.Interface;
@using QEX.Components.Extensions.Classes;
@using QEX.Resources.Data;
@inject IExtensionService ExtensionService;


<div class="store-container">

    <!-- Поиск -->
    <div class="store-header">
        <input class="store-search"
               @bind="Search"
               placeholder="Поиск расширений..." />
    </div>

    <!-- Вкладки -->
    <div class="store-tabs">
        <button class="@(ActiveTab == StoreTab.Store ? "active" : "")"
                @onclick="() => SwitchTab(StoreTab.Store)">
            Магазин
        </button>

        <button class="@(ActiveTab == StoreTab.Installed ? "active" : "")"
                @onclick="() => SwitchTab(StoreTab.Installed)">
            Моя библиотека
        </button>
    </div>

    <!-- Магазин -->
    @if (ActiveTab == StoreTab.Store)
    {
        <div class="store-grid">
            <p>Магазин пока пуст</p>
        </div>
    }

    <!-- Установленные -->
    @if (ActiveTab == StoreTab.Installed)
    {
        <div class="store-grid">
            @foreach (var ext in SearchExtensions())
            {
                <div class="store-card" @onclick="() => OpenExtension(ext.Manifest.Name)">
                    <h4>@ext.Manifest.Name</h4>
                    <p>@ext.Manifest.Description</p>
                </div>
            }
        </div>
    }
</div>
<style>
    .store-root {
        width: 100%;
        height: 100%;
        background: #2f3136;
        color: #fff;
        font-family: "Segoe UI", sans-serif;
        display: flex;
        flex-direction: column;
    }

    .store-header {
        padding: 16px;
        background: #202225;
        border-bottom: 1px solid #18191c;
    }

    .store-search {
        width: 100%;
        padding: 10px 14px;
        border-radius: 6px;
        border: none;
        outline: none;
        background: #3a3c43;
        color: #fff;
        font-size: 14px;
        transition: background .2s ease;
    }

        .store-search:focus {
            background: #4a4c53;
        }

    .store-tabs {
        display: flex;
        background: #202225;
        border-bottom: 1px solid #18191c;
    }

        .store-tabs button {
            flex: 1;
            padding: 12px 0;
            background: none;
            border: none;
            color: #b9bbbe;
            font-size: 15px;
            cursor: pointer;
            transition: background .2s ease, color .2s ease;
        }

            .store-tabs button:hover {
                background: #2f3136;
                color: #fff;
            }

            .store-tabs button.active {
                background: #2f3136;
                color: #fff;
                font-weight: 600;
            }

    .store-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
        gap: 18px;
        padding: 20px;
    }

    .card {
        background: #36393f;
        border-radius: 10px;
        padding: 18px;
        cursor: pointer;
        border: 1px solid #2a2c31;
        box-shadow: 0 2px 6px rgba(0,0,0,0.25);
        transition: transform .15s ease, box-shadow .15s ease, border-color .15s ease;
    }

        .card:hover {
            transform: translateY(-4px);
            box-shadow: 0 6px 14px rgba(0,0,0,0.35);
            border-color: #5865f2;
        }

    .card-title {
        font-size: 17px;
        font-weight: bold;
        margin-bottom: 6px;
        color: #fff;
    }

    .card-desc {
        font-size: 14px;
        color: #b9bbbe;
    }

    .empty {
        color: #b9bbbe;
        font-size: 16px;
        padding: 20px;
    }

    .store-container {
        width: 100%;
        height: 100%;
        background: #2f3136;
        color: #fff;
        font-family: "Segoe UI", sans-serif;
        display: flex;
        flex-direction: column;
    }

    .store-grid {
        flex: 1; /* ← растягиваем на всю высоту */
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
        gap: 18px;
        padding: 20px;
        background: #2f3136; /* ← тёмный фон */
        overflow-y: auto; /* ← скролл если много карточек */
    }

    .store-card {
        background: #36393f;
        border-radius: 10px;
        padding: 18px;
        cursor: pointer;
        border: 1px solid #2a2c31;
        box-shadow: 0 2px 6px rgba(0,0,0,0.25);
        transition: transform .15s ease, box-shadow .15s ease, border-color .15s ease;
    }

        .store-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 6px 14px rgba(0,0,0,0.35);
            border-color: #5865f2;
        }

    .store-card-title {
        font-size: 17px;
        font-weight: bold;
        margin-bottom: 6px;
        color: #fff;
    }

    .store-card-desc {
        font-size: 14px;
        color: #b9bbbe;
    }

</style>

@code {
    [Parameter] public EventCallback OnClose { get; set; }
    string Search = "";

    enum StoreTab { Store, Installed }
    StoreTab ActiveTab = StoreTab.Installed;

    List<ExtensionInfo> installedExtensions = new();

    protected override void OnInitialized()
    {
        var loader = new ExtensionLoader(ExtensionService);
        installedExtensions = loader.LoadInstalled();
        base.OnInitialized();
    }

    void SwitchTab(StoreTab tab) => ActiveTab = tab;

    void OpenExtension(string name)
    {
        try
        {
            ExtensionService.CloseExtension();
            ExtensionService.OpenExtensionByName(name, new Dictionary<string, object>());
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Failed to open extension: {ex.Message}");
            ExtensionService.CloseExtension();
        }
    }

    IEnumerable<ExtensionInfo> SearchExtensions()
    {
        if (string.IsNullOrWhiteSpace(Search))
            return installedExtensions;

        var query = Search.Trim().ToLower();
        return installedExtensions
            .Where(x => x.Manifest.Name.ToLower().Contains(query));
    }
}
