@using Chats.Services
@using Chats.Classes
@inject ChatService Chat

<div class="sidebar-root">
    <!-- Левая колонка с иконками групп и ЛС -->
    <div class="servers-bar">
        <div class="server-icon dm"
             title="Личные сообщения"
             @onclick="() => Chat.SwitchMode(ChatService.ChatMode.DirectMessages)">
            ЛС
        </div>

        @foreach (var g in Chat.Guilds)
        {
            <div class="server-icon @(Chat.CurrentGuild == g ? "active" : "")"
                 title="@g.Name"
                 @onclick="() => OnGuildClick(g)">
                @g.Name.Substring(0, 1)
            </div>
        }
    </div>

    <!-- Правая часть боковой панели -->
    <div class="sidebar-main">
        <div class="top-tabs">
            <button class="tab-btn @(Chat.CurrentMode == ChatService.ChatMode.Guilds ? "active" : "")"
                    @onclick="() => Chat.SwitchMode(ChatService.ChatMode.Guilds)">
                Группы
            </button>

            <button class="tab-btn @(Chat.CurrentMode == ChatService.ChatMode.DirectMessages ? "active" : "")"
                    @onclick="() => Chat.SwitchMode(ChatService.ChatMode.DirectMessages)">
                Личные
            </button>
        </div>

        <div class="sidebar-content">
            @if (Chat.CurrentMode == ChatService.ChatMode.Guilds)
            {
                <!-- здесь показываем каналы выбранной группы -->
                <ChannelList />
            }
            else
            {
                <!-- здесь показываем личные -->
                <FriendList />
            }
        </div>
    </div>
</div>

<style>
    .sidebar-root {
        display: flex;
        height: 100%;
        background: #202225;
        color: white;
    }

    /* Левая колонка с иконками серверов */
    .servers-bar {
        width: 72px;
        background: #202225;
        padding: 8px 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
    }

    .server-icon {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        background: #36393f;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        font-weight: bold;
    }

        .server-icon.dm {
            background: #5865F2;
        }

        .server-icon.active {
            border-radius: 16px;
            background: #5865F2;
        }

    /* Правая часть боковой панели */
    .sidebar-main {
        width: 220px;
        background: #2f3136;
        display: flex;
        flex-direction: column;
    }

    .top-tabs {
        display: flex;
        gap: 4px;
        padding: 8px;
    }

    .tab-btn {
        flex: 1;
        padding: 6px 8px;
        background: #3a3c43;
        border: none;
        color: white;
        border-radius: 4px;
        cursor: pointer;
        font-size: 12px;
    }

        .tab-btn.active {
            background: #5865F2;
        }

    .sidebar-content {
        flex: 1;
        overflow: hidden;
    }
</style>

@code {
    private void OnGuildClick(Guild g)
    {
        Chat.SelectGuild(g);
        Chat.SwitchMode(ChatService.ChatMode.Guilds);
    }

    protected override void OnInitialized()
    {
        Chat.OnUIChanged += StateHasChanged;
    }
}